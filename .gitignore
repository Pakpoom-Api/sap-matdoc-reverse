# ── OS files ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Windows ───────────────────────────────────
*.lnk
*.tmp
$RECYCLE.BIN/

# ── SAP / ABAP tools ──────────────────────────
# ADT project files (Eclipse)
.project
.classpath
.settings/
*.abapgit.xml.bak

# abapGit local settings
.abapgit_local/


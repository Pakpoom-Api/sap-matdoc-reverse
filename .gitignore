node_modules/
.fioritools/
*.fiori-cache
dist/
webapp/test-results/

# SAP BAS (Business Application Studio)
.vscode/
*.vsix

# ── Editor ────────────────────────────────────
*.swp
*.swo
*~
.idea/

# ── Logs ──────────────────────────────────────
*.log
npm-debug.log*

# ── Secrets — never commit these ──────────────
*.env
.env.*
secrets.txt
token.txt
